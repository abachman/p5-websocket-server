{
  "name": "p5-websocket-server",
  "description": "A lightweight realtime server for hosting p5js sketch-to-sketch communication.",
  "author": "Adam Bachman @abachman",
  "version": "1.1.1",
  "private": false,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "start": "PORT=4004 node dist/app.js",
    "start-dev": "PORT=4004 nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/app.ts src/lib/**/*.ts",
    "deploy": "pm2 deploy ecosystem.config.js production"
  },
  "dependencies": {
    "bufferutil": "^4.1.0",
    "express": "5.2.1",
    "express-handlebars": "8.0.7",
    "express-session": "1.19.0",
    "frameguard": "^3.1.0",
    "morgan": "^1.10.1",
    "nconf": "^0.11.4",
    "utf-8-validate": "^5.0.10",
    "uuid": "^7.0.3",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/morgan": "^1.9.10",
    "@types/uuid": "^8.3.4",
    "@types/ws": "^7.4.7",
    "typescript-eslint": "^8.58.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^26.6.3",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "ts-node": "^9.1.1",
    "typescript": "^6.0.2"
  }
}
